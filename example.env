# CodeGraph configuration
# Copy this file to .env and adjust values for your project.
# Load before running: source .env && codegraph <command>

# ── Storage ──────────────────────────────────────────────────
export CODEGRAPH_SQLITE_PATH="./codegraph.db"
export CODEGRAPH_OUTPUT_DIR="./codegraph_output"

# ── Parsing ──────────────────────────────────────────────────
export CODEGRAPH_DEFAULT_MODE="full"
export CODEGRAPH_MAX_FILE_SIZE_KB="500"
export CODEGRAPH_INCLUDE_EXTERNAL_NODES="true"
export CODEGRAPH_DEFAULT_EXPORT_FORMAT="json"

# ── MCP Server ───────────────────────────────────────────────
export CODEGRAPH_MCP_HOST="127.0.0.1"
export CODEGRAPH_MCP_PORT="8765"
export CODEGRAPH_MCP_TRANSPORT="sse"

# ── Vector Store (optional, leave empty to disable) ──────────
export CODEGRAPH_VECTOR_DB_URL=""
export CODEGRAPH_VECTOR_DB_TYPE=""
export CODEGRAPH_VECTOR_COLLECTION="codegraph"

# ── LLM Summaries (optional, leave empty to disable) ─────────
export CODEGRAPH_LLM_ENDPOINT=""
export CODEGRAPH_LLM_MODEL="mistral:7b-instruct-q4_K_M"
