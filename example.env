# CodeGraph configuration
# Copy to .env in your project directory for project-specific settings,
# or to ~/.codegraph/.env for global defaults.
# Values are loaded automatically -- no need to `source` this file.

# ── Storage ──────────────────────────────────────────────────
# CODEGRAPH_SQLITE_PATH=~/.codegraph/codegraph.db
# CODEGRAPH_OUTPUT_DIR=./codegraph_output

# ── Parsing ──────────────────────────────────────────────────
# CODEGRAPH_DEFAULT_MODE=full
# CODEGRAPH_MAX_FILE_SIZE_KB=500
# CODEGRAPH_INCLUDE_EXTERNAL_NODES=true
# CODEGRAPH_DEFAULT_EXPORT_FORMAT=json

# ── MCP Server ───────────────────────────────────────────────
# CODEGRAPH_MCP_HOST=127.0.0.1
# CODEGRAPH_MCP_PORT=8765
# CODEGRAPH_MCP_TRANSPORT=sse

# ── Vector Store (optional, leave empty to disable) ──────────
# CODEGRAPH_VECTOR_DB_URL=
# CODEGRAPH_VECTOR_DB_TYPE=
# CODEGRAPH_VECTOR_COLLECTION=codegraph

# ── LLM Summaries (optional, leave empty to disable) ─────────
# CODEGRAPH_LLM_ENDPOINT=
# CODEGRAPH_LLM_MODEL=mistral:7b-instruct-q4_K_M
