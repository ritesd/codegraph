# CodeGraph configuration
# Copy to .env in your project directory for project-specific settings,
# or to ~/.codegraph/.env for global defaults.
# Values are loaded automatically -- no need to `source` this file.

# ── Storage ──────────────────────────────────────────────────
# CODEGRAPH_SQLITE_PATH=~/.codegraph/codegraph.db
# CODEGRAPH_OUTPUT_DIR=./codegraph_output

# ── Parsing ──────────────────────────────────────────────────
# CODEGRAPH_DEFAULT_MODE=full
# CODEGRAPH_MAX_FILE_SIZE_KB=500
# CODEGRAPH_INCLUDE_EXTERNAL_NODES=true
# CODEGRAPH_DEFAULT_EXPORT_FORMAT=json

# ── MCP Server ───────────────────────────────────────────────
# CODEGRAPH_MCP_HOST=127.0.0.1
# CODEGRAPH_MCP_PORT=8765
# CODEGRAPH_MCP_TRANSPORT=sse

# ── Vector Store (optional) ──────────────────────────────────
# CODEGRAPH_VECTOR_DB_URL=http://localhost:6333
# CODEGRAPH_VECTOR_DB_TYPE=qdrant
# CODEGRAPH_VECTOR_COLLECTION=codegraph

# ── Embeddings (optional) ────────────────────────────────────
# Falls back to LLM_ENDPOINT / LLM_API_KEY if not set separately.
#
# Local (Ollama):
#   CODEGRAPH_EMBEDDING_ENDPOINT=http://localhost:11434
#   CODEGRAPH_EMBEDDING_MODEL=nomic-embed-text
#
# OpenAI:
#   CODEGRAPH_EMBEDDING_ENDPOINT=https://api.openai.com
#   CODEGRAPH_EMBEDDING_MODEL=text-embedding-3-small
#   CODEGRAPH_EMBEDDING_API_KEY=sk-...
#
# Azure OpenAI:
#   CODEGRAPH_EMBEDDING_ENDPOINT=https://<resource>.openai.azure.com/openai/deployments/<deployment>
#   CODEGRAPH_EMBEDDING_MODEL=text-embedding-3-small
#   CODEGRAPH_EMBEDDING_API_KEY=<azure-key>
#   CODEGRAPH_EMBEDDING_API_VERSION=2024-06-01

# ── LLM Summaries (optional) ─────────────────────────────────
#
# Local (Ollama):
#   CODEGRAPH_LLM_ENDPOINT=http://localhost:11434
#   CODEGRAPH_LLM_MODEL=mistral:7b-instruct-q4_K_M
#
# OpenAI:
#   CODEGRAPH_LLM_ENDPOINT=https://api.openai.com
#   CODEGRAPH_LLM_MODEL=gpt-4o-mini
#   CODEGRAPH_LLM_API_KEY=sk-...
#
# Azure OpenAI:
#   CODEGRAPH_LLM_ENDPOINT=https://<resource>.openai.azure.com/openai/deployments/<deployment>
#   CODEGRAPH_LLM_MODEL=gpt-4o-mini
#   CODEGRAPH_LLM_API_KEY=<azure-key>
#   CODEGRAPH_LLM_API_VERSION=2024-06-01
